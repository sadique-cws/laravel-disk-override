{
    "name": "comestro/laravel-disk-override",
    "description": "A drop-in Laravel FilesystemServiceProvider replacement resolving overlapping URI route collision errors.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Comestro",
            "email": "sadique@comestro.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Comestro\\LaravelDiskOverride\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Comestro\\LaravelDiskOverride\\FilesystemServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
